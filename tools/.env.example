# DATABASE_URL points at the same database the game uses for ai_memory.
#
# Local SQLite (most common for dev):
DATABASE_URL=sqlite:///../../src/game/server/ai_memory.db3
#
# Local Postgres with pgvector:
# DATABASE_URL=postgres://user:pass@localhost:5432/fcm_ai_memory
#
# Railway: reference the game service's DATABASE_URL via Railway service
# variables — do NOT paste the credentials into a .env file.

OPENAI_API_KEY=sk-replace-me
